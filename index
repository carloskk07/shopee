  <style>
    @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap");

    :root {
      --bg-deep: #020617;
      --accent: #38bdf8;
      --accent-2: #22d3ee;
      --text: #f8fafc;
      --muted: #94a3b8;
      --border: rgba(255, 255, 255, 0.09);
      --shadow-dark: 0 24px 60px rgba(2, 6, 23, 0.55);
      --shadow-accent: 0 18px 44px rgba(56, 189, 248, 0.18);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      background:
        radial-gradient(circle at 50% -20%, rgba(30, 64, 175, 0.42), transparent 34%),
        radial-gradient(circle at 0% 100%, rgba(15, 23, 42, 0.72), transparent 40%),
        linear-gradient(180deg, #020617 0%, #020617 100%);
      color: var(--text);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    a, button { -webkit-tap-highlight-color: transparent; }

    .bg-glow {
      position: fixed;
      inset: 0;
      z-index: -2;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% -12%, rgba(59, 130, 246, 0.24), transparent 38%),
        radial-gradient(circle at 100% 5%, rgba(34, 211, 238, 0.08), transparent 24%),
        radial-gradient(circle at 0% 100%, rgba(15, 23, 42, 0.32), transparent 38%);
      filter: blur(10px);
    }

    .bg-noise {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
      opacity: 0.04;
      background-image:
        radial-gradient(circle at 20% 20%, #ffffff 0.7px, transparent 0.8px),
        radial-gradient(circle at 80% 35%, #ffffff 0.6px, transparent 0.7px),
        radial-gradient(circle at 30% 80%, #ffffff 0.6px, transparent 0.7px);
      background-size: 170px 170px;
    }

    .glass-card {
      background: linear-gradient(180deg, rgba(15, 23, 42, 0.78), rgba(15, 23, 42, 0.64));
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-dark);
    }

    .hero-shell {
      position: relative;
      overflow: hidden;
      border-radius: 2.4rem;
    }

    .hero-shell::before {
      content: "";
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(
        135deg,
        rgba(56, 189, 248, 0.36),
        rgba(255, 255, 255, 0.05),
        rgba(34, 211, 238, 0.16)
      );
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }

    .premium-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid rgba(56, 189, 248, 0.16);
      color: #dbeafe;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .mini-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.7rem 0.85rem;
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.05);
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .avatar-wrap {
      position: relative;
      display: inline-block;
    }

    .avatar-wrap::after {
      content: "";
      position: absolute;
      inset: -10px;
      z-index: -1;
      border-radius: 2.6rem;
      background: radial-gradient(circle, rgba(56, 189, 248, 0.2), transparent 68%);
      filter: blur(10px);
    }

    .link-item {
      position: relative;
      overflow: hidden;
      transition:
        transform 0.35s cubic-bezier(0.23, 1, 0.32, 1),
        border-color 0.35s ease,
        background 0.35s ease,
        box-shadow 0.35s ease;
      will-change: transform;
    }

    .link-item:hover,
    .link-item:focus-visible {
      transform: scale(1.015) translateY(-4px);
      background: rgba(30, 41, 59, 0.92);
      border-color: rgba(56, 189, 248, 0.38);
      box-shadow: 0 26px 50px rgba(2, 6, 23, 0.46), 0 0 0 1px rgba(56, 189, 248, 0.07);
      outline: none;
    }

    .link-item::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255,255,255,0.02) 35%,
        rgba(255,255,255,0.08) 50%,
        rgba(255,255,255,0.02) 65%,
        transparent 100%
      );
      transform: translateX(-120%);
      transition: transform 0.9s cubic-bezier(0.23, 1, 0.32, 1);
      pointer-events: none;
    }

    .link-item:hover::before,
    .link-item:focus-visible::before {
      transform: translateX(120%);
    }

    .featured-link {
      background:
        linear-gradient(180deg, rgba(8, 47, 73, 0.54), rgba(15, 23, 42, 0.84)),
        linear-gradient(135deg, rgba(56, 189, 248, 0.08), transparent 60%);
      border: 1px solid rgba(56, 189, 248, 0.24);
      box-shadow: var(--shadow-accent), var(--shadow-dark);
    }

    .featured-link::after {
      content: "";
      position: absolute;
      top: -55%;
      left: -55%;
      width: 180%;
      height: 180%;
      background: linear-gradient(45deg, transparent, rgba(255,255,255,0.08), transparent);
      transform: rotate(20deg);
      animation: shine 5.2s infinite;
      pointer-events: none;
    }

    @keyframes shine {
      0% { left: -160%; }
      18% { left: 140%; }
      100% { left: 140%; }
    }

    .featured-pulse {
      position: absolute;
      inset: auto auto -42px -18px;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(56, 189, 248, 0.22), transparent 65%);
      pointer-events: none;
      animation: pulseGlow 3s ease-in-out infinite;
    }

    @keyframes pulseGlow {
      0%, 100% { transform: scale(1); opacity: 0.8; }
      50% { transform: scale(1.12); opacity: 1; }
    }

    .share-btn {
      box-shadow: 0 6px 24px rgba(56, 189, 248, 0.28);
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease,
        background 0.25s ease;
    }

    .share-btn:hover,
    .share-btn:focus-visible {
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 10px 30px rgba(56, 189, 248, 0.36);
      outline: none;
    }

    .social-btn {
      transition:
        transform 0.28s ease,
        background 0.28s ease,
        border-color 0.28s ease,
        color 0.28s ease;
    }

    .social-btn:hover,
    .social-btn:focus-visible {
      transform: translateY(-4px);
      outline: none;
    }

    .floating-cta {
      position: sticky;
      bottom: 0;
      z-index: 35;
      padding-top: 1rem;
      background: linear-gradient(180deg, rgba(2,6,23,0), rgba(2,6,23,0.9) 35%, rgba(2,6,23,0.98) 100%);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .cta-button {
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, #0ea5e9 0%, #22d3ee 100%);
      color: #fff;
      font-weight: 800;
      box-shadow:
        0 14px 30px rgba(14, 165, 233, 0.34),
        inset 0 1px 0 rgba(255,255,255,0.22);
      transition:
        transform 0.22s ease,
        box-shadow 0.22s ease,
        filter 0.22s ease;
    }

    .cta-button:hover,
    .cta-button:focus-visible {
      transform: translateY(-2px) scale(1.01);
      box-shadow:
        0 18px 38px rgba(14, 165, 233, 0.42),
        inset 0 1px 0 rgba(255,255,255,0.22);
      filter: saturate(1.05);
      outline: none;
    }

    .cta-button::after {
      content: "";
      position: absolute;
      top: -30%;
      left: -35%;
      width: 40%;
      height: 160%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
      transform: rotate(18deg);
      animation: ctaSweep 4.6s ease-in-out infinite;
      pointer-events: none;
    }

    @keyframes ctaSweep {
      0% { left: -45%; }
      18% { left: 120%; }
      100% { left: 120%; }
    }

    .toast {
      visibility: hidden;
      min-width: 220px;
      max-width: calc(100vw - 32px);
      background: linear-gradient(135deg, #0ea5e9, #22d3ee);
      color: #fff;
      text-align: center;
      border-radius: 1rem;
      padding: 0.95rem 1rem;
      position: fixed;
      z-index: 100;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(16px);
      font-weight: 700;
      opacity: 0;
      transition:
        opacity 0.3s ease,
        transform 0.3s ease,
        visibility 0.3s ease;
      box-shadow: 0 14px 32px rgba(14, 165, 233, 0.28);
    }

    .toast.show {
      visibility: visible;
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .fade-in-up {
      opacity: 0;
      transform: translateY(18px);
      animation: fadeInUp 0.68s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }

    .delay-100 { animation-delay: 100ms; }
    .delay-200 { animation-delay: 200ms; }
    .delay-300 { animation-delay: 300ms; }
    .delay-400 { animation-delay: 400ms; }

    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .disclaimer-text {
      font-size: 0.72rem;
      line-height: 1.6;
      color: #94a3b8;
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(56, 189, 248, 0.4);
      border-radius: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: rgba(56, 189, 248, 0.8);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .sr-only-focusable:focus {
      position: static;
      width: auto;
      height: auto;
      margin: 0;
      overflow: visible;
      clip: auto;
      white-space: normal;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation: none !important;
        transition: none !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
