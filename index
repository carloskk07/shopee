  <div
    id="modal-overlay"
    class="fixed inset-0 hidden items-center justify-center bg-black/90 p-4 backdrop-blur-md z-50"
    aria-modal="true"
    role="dialog"
    aria-labelledby="modal-title"
    aria-hidden="true"
  >
    <div class="relative w-full max-w-md rounded-[2.2rem] border border-white/10 bg-slate-900 p-8 shadow-2xl">
      <button
        id="closeModalButton"
        type="button"
        class="absolute right-5 top-5 text-slate-500 hover:text-white"
        aria-label="Fechar"
      >
        <i class="fas fa-times text-xl" aria-hidden="true"></i>
      </button>
      <h2 id="modal-title" class="mb-6 text-2xl font-bold text-white">Título</h2>
      <div
        id="modal-content"
