  </div>

  <script>
    (function (w, d, t) {
      w.TiktokAnalyticsObject = t;
      var ttq = (w[t] = w[t] || []);
      ttq.methods = [
        "page", "track", "identify", "instances", "debug", "on", "off",
        "once", "ready", "alias", "group", "enableCookie", "disableCookie"
      ];
      ttq.setAndDefer = function (target, method) {
        target[method] = function () {
          target.push([method].concat(Array.prototype.slice.call(arguments, 0)));
        };
      };
      for (var i = 0; i < ttq.methods.length; i++) {
        ttq.setAndDefer(ttq, ttq.methods[i]);
      }
      ttq.load = function (pixelId, options) {
        if (!pixelId || pixelId === "YOUR_TIKTOK_PIXEL_ID") return;
        var scriptUrl = "https://analytics.tiktok.com/i18n/pixel/events.js";
        ttq._i = ttq._i || {};
        ttq._i[pixelId] = [];
        ttq._i[pixelId]._u = scriptUrl;
        ttq._t = ttq._t || {};
        ttq._t[pixelId] = +new Date();
        ttq._o = ttq._o || {};
        ttq._o[pixelId] = options || {};
        var script = d.createElement("script");
        script.type = "text/javascript";
        script.async = true;
        script.src = scriptUrl + "?sdkid=" + encodeURIComponent(pixelId) + "&lib=" + t;
        var firstScript = d.getElementsByTagName("script")[0];
        if (firstScript && firstScript.parentNode) {
          firstScript.parentNode.insertBefore(script, firstScript);
        } else if (d.head) {
          d.head.appendChild(script);
        }
      };

      var pixelId = (window.APP_CONFIG && window.APP_CONFIG.tiktokPixelId) || "";
      if (pixelId && pixelId !== "YOUR_TIKTOK_PIXEL_ID") {
        ttq.load(pixelId);
        ttq.page();
      }
    })(window, document, "ttq");
  </script>

  <script>
    (() => {
      "use strict";

      const config = window.APP_CONFIG || {};

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function safeText(value, fallback = "") {
        return typeof value === "string" && value.trim() ? value : fallback;
      }

      function isSafeHttpUrl(value) {
        if (typeof value !== "string" || !value.trim()) return false;
        try {
          const url = new URL(value, window.location.origin);
          return url.protocol === "http:" || url.protocol === "https:";
        } catch {
          return false;
        }
      }

      function isSafeWhatsAppUrl(value) {
        if (typeof value !== "string" || !value.trim()) return false;
        try {
          const url = new URL(value, window.location.origin);
          return url.protocol === "https:" && (url.hostname === "wa.me" || url.hostname.endsWith(".whatsapp.com"));
        } catch {
          return false;
        }
      }

      const toast = document.getElementById("toast");
      const shareButton = document.getElementById("shareButton");
      const modalOverlay = document.getElementById("modal-overlay");
      const modalTitle = document.getElementById("modal-title");
      const modalContent = document.getElementById("modal-content");
      const closeModalButton = document.getElementById("closeModalButton");
      const confirmModalButton = document.getElementById("confirmModalButton");
      const brandLogo = document.getElementById("brandLogo");

      let toastTimeout = null;
      let lastFocusedElement = null;

      const modalContentMap = {
        privacy: {
          title: "Privacidade",
          paragraphs: [
            "Sua privacidade é tratada com seriedade.",
            "Coletamos apenas dados necessários para navegação, medição de desempenho, atendimento e análise de campanhas.",
            "Informações enviadas por formulários, mensagens ou parâmetros de campanha podem ser usadas para melhorar a experiência e compreender o desempenho do tráfego.",
            "Você pode solicitar informações sobre tratamento de dados pelos canais oficiais da empresa."
          ]
        },
        terms: {
          title: "Termos de uso",
          paragraphs: [
            "Uso claro e responsável da página.",
            "Ao navegar neste site, você concorda com os termos de uso, políticas publicadas e condições comerciais aplicáveis.",
            "Conteúdos, elementos visuais e textos pertencem à marca, salvo indicação em contrário.",
            "Ofertas, disponibilidade, horários de atendimento e condições podem ser alterados sem aviso prévio."
          ]
        },
        company: {
          title: "Informações da empresa",
          paragraphs: []
        }
      };

      function buildCompanyParagraphs() {
        modalContentMap.company.paragraphs = [
          "Dados comerciais visíveis e atualizáveis.",
          `Razão social: ${safeText(config.companyName, "Sua Empresa Oficial Ltda.")}`,
          `CNPJ: ${safeText(config.companyCnpj, "00.000.000/0001-00")}`,
          `Contato: ${safeText(config.companyEmail, "contato@suaempresa.com")}`,
          `Endereço: ${safeText(config.companyAddress, "Rua Exemplo, 123 - Cidade/UF")}`
        ];
      }

      function setText(id, value, fallback = "") {
        const el = document.getElementById(id);
        if (el) el.textContent = safeText(value, fallback);
      }

      function setSafeHref(id, value, fallback) {
        const el = document.getElementById(id);
        const finalValue = isSafeHttpUrl(value) ? value : fallback;
        if (el && finalValue) {
          el.href = finalValue;
          if (el.target === "_blank") {
            el.rel = "noopener noreferrer";
          }
        }
      }

      function setSafeWhatsAppHref(id, value, fallback) {
        const el = document.getElementById(id);
        const finalValue = isSafeWhatsAppUrl(value) ? value : fallback;
        if (el && finalValue) {
          el.href = finalValue;
          if (el.target === "_blank") {
            el.rel = "noopener noreferrer";
          }
        }
      }

      function applyConfig() {
        document.title = safeText(config.pageTitle, document.title);

        const metaDescription = document.querySelector('meta[name="description"]');
        if (metaDescription) {
          metaDescription.setAttribute("content", safeText(config.pageDescription, metaDescription.getAttribute("content") || ""));
        }

        const ogTitle = document.querySelector('meta[property="og:title"]');
        if (ogTitle) {
          ogTitle.setAttribute("content", safeText(config.pageTitle, ogTitle.getAttribute("content") || ""));
        }

        const ogDescription = document.querySelector('meta[property="og:description"]');
        if (ogDescription) {
          ogDescription.setAttribute("content", safeText(config.pageDescription, ogDescription.getAttribute("content") || ""));
        }

        const ogImage = document.querySelector('meta[property="og:image"]');
        if (ogImage && isSafeHttpUrl(config.ogImage)) {
          ogImage.setAttribute("content", config.ogImage);
        }

        const favicon = document.querySelector('link[rel="icon"]');
        if (favicon && isSafeHttpUrl(config.faviconUrl)) {
          favicon.setAttribute("href", config.faviconUrl);
        }

        setText("brandHandle", config.brandHandle, "@suamarca.oficial");
        setText("heroTitle", config.heroTitle, "Veja por aqui o que está em destaque, o atendimento direto e os acessos mais importantes da marca.");
        setText("heroSubtitle", config.heroSubtitle, "Tudo reunido para facilitar seu próximo clique de forma rápida, bonita e envolvente.");

        setText("primaryTitle", config.primaryTitle, "Ver destaque principal");
        setText("primaryTag", config.primaryTag, "acesse agora");
        setText("primaryDescription", config.primaryDescription, "Entre no acesso principal e descubra o conteúdo, página ou oportunidade que está chamando mais atenção.");
        setText("stickyCtaText", config.stickyCtaText || config.primaryTitle, "Ver destaque principal");

        setText("whatsappTitle", config.whatsappTitle, "Chamar no WhatsApp");
        setText("whatsappDescription", config.whatsappDescription, "Converse com a equipe de forma rápida e prática");

        setText("storeTitle", config.storeTitle, "Descobrir loja oficial");
        setText("storeDescription", config.storeDescription, "Explore novidades, produtos e opções disponíveis em poucos toques");

        setText("companyCopyright", config.companyCopyright, "© 2026 Sua Empresa Oficial");
        setText("companyCnpj", `CNPJ: ${safeText(config.companyCnpj, "00.000.000/0001-00")}`);
        setText("companyEmail", `Contato: ${safeText(config.companyEmail, "contato@suaempresa.com")}`);
        setText("companyAddress", `Endereço: ${safeText(config.companyAddress, "Rua Exemplo, 123 - Cidade/UF")}`);

        setSafeHref("primaryLink", config.primaryLink, "https://exemplo.com");
        setSafeHref("stickyPrimaryLink", config.primaryLink, "https://exemplo.com");
        setSafeWhatsAppHref("whatsappLink", config.whatsappLink, "https://wa.me/5500000000000");
        setSafeHref("storeLink", config.storeLink, "https://exemplo.com/loja");
        setSafeHref("instagramLink", config.instagramLink, "https://instagram.com/");
        setSafeHref("tiktokLink", config.tiktokLink, "https://www.tiktok.com/");
        setSafeHref("youtubeLink", config.youtubeLink, "https://youtube.com/");

        if (brandLogo) {
          const logoUrl = isSafeHttpUrl(config.logoUrl) ? config.logoUrl : "";
          const logoFallback = isSafeHttpUrl(config.logoFallback) ? config.logoFallback : "";
          brandLogo.src = logoUrl || logoFallback;
          brandLogo.alt = `Logotipo de ${safeText(config.brandName, "Sua Marca")}`;
          brandLogo.onerror = function () {
            this.onerror = null;
            if (logoFallback && this.src !== logoFallback) {
              this.src = logoFallback;
            }
          };
        }

        buildCompanyParagraphs();
      }

      function trackEvent(eventName, payload = {}) {
        try {
          if (window.ttq && typeof window.ttq.track === "function") {
            window.ttq.track(eventName, payload);
          }
        } catch (error) {
          console.error("Erro no rastreamento TikTok:", error);
        }
      }

      function showToast(message = "Link copiado com sucesso.") {
        if (!toast) return;
        toast.textContent = message;
        toast.classList.add("show");
        window.clearTimeout(toastTimeout);
        toastTimeout = window.setTimeout(() => {
          toast.classList.remove("show");
        }, 2600);
      }

      async function copyTextToClipboard(text) {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(text);
            return true;
          }
        } catch (_) {}

        try {
          const textarea = document.createElement("textarea");
          textarea.value = text;
          textarea.setAttribute("readonly", "");
          textarea.style.position = "fixed";
          textarea.style.opacity = "0";
          textarea.style.pointerEvents = "none";
          textarea.style.left = "-9999px";
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          textarea.setSelectionRange(0, textarea.value.length);
          const copied = document.execCommand("copy");
          textarea.remove();
          return copied;
        } catch {
          return false;
        }
      }

      async function sharePage() {
        const shareData = {
          title: document.title,
          text: safeText(config.pageDescription, "Veja o destaque principal e acesse os links mais importantes."),
          url: window.location.href
        };

        try {
          if (navigator.share) {
            await navigator.share(shareData);
            trackEvent("Share", {
              method: "native_share",
              page_name: "link_hub"
            });
            return;
          }

          const copied = await copyTextToClipboard(window.location.href);
          if (copied) {
            showToast("Link copiado para compartilhamento.");
            trackEvent("ClickButton", {
              content_name: "copy_page_url",
              page_name: "link_hub"
            });
          } else {
            showToast("Não foi possível copiar o link.");
          }
        } catch (error) {
          console.error("Erro ao compartilhar:", error);
        }
      }

      function renderModalParagraphs(paragraphs) {
        if (!modalContent) return;
        modalContent.replaceChildren();

        paragraphs.forEach((paragraph, index) => {
          const p = document.createElement("p");
          p.className = index === 0
            ? "mb-4 text-white font-semibold italic"
            : "mb-4";
          p.textContent = paragraph;
          modalContent.appendChild(p);
        });

        const last = modalContent.lastElementChild;
        if (last) {
          last.classList.remove("mb-4");
        }
      }

      function openModal(type) {
        const modalData = modalContentMap[type];
        if (!modalData || !modalOverlay || !modalTitle || !modalContent) return;

        lastFocusedElement = document.activeElement;
        modalTitle.textContent = modalData.title;
        renderModalParagraphs(modalData.paragraphs);
        modalOverlay.classList.remove("hidden");
        modalOverlay.classList.add("flex");
        modalOverlay.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";

        if (closeModalButton) {
          window.setTimeout(() => closeModalButton.focus(), 0);
        }

        trackEvent("ViewContent", {
          content_name: "modal_" + type,
          page_name: "link_hub"
        });
      }

      function closeModal() {
        if (!modalOverlay) return;
        modalOverlay.classList.add("hidden");
        modalOverlay.classList.remove("flex");
        modalOverlay.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";

        if (lastFocusedElement && typeof lastFocusedElement.focus === "function") {
          lastFocusedElement.focus();
        }
      }

      function safeStorageGet(key) {
        try {
          return window.localStorage.getItem(key);
        } catch {
          return null;
        }
      }

      function safeStorageSet(key, value) {
        try {
          window.localStorage.setItem(key, value);
        } catch {}
      }

      function getAllowedQueryParams() {
        const params = new URLSearchParams(window.location.search);
        const allowedKeys = [
          "ttclid",
          "utm_source",
          "utm_medium",
          "utm_campaign",
          "utm_content",
          "utm_term"
        ];

        const saved = new URLSearchParams();
        allowedKeys.forEach((key) => {
          const value = params.get(key);
          if (value) saved.set(key, value);
        });

        return saved;
      }

      function persistAttribution() {
        const params = getAllowedQueryParams();
        if ([...params.keys()].length > 0) {
          safeStorageSet("saved_attribution_params", params.toString());
        }
      }

      function appendAttributionToLinks() {
        const saved = safeStorageGet("saved_attribution_params");
        if (!saved) return;

        const links = document.querySelectorAll("a[href^='http']");
        links.forEach((link) => {
          try {
            const url = new URL(link.href);
            const params = new URLSearchParams(saved);

            params.forEach((value, key) => {
              if (!url.searchParams.has(key)) {
                url.searchParams.set(key, value);
              }
            });

            link.href = url.toString();
          } catch {}
        });
      }

      function bindTrackedLinks() {
        const trackedElements = document.querySelectorAll("[data-track]");
        trackedElements.forEach((el) => {
          el.addEventListener("click", () => {
            trackEvent("ClickButton", {
              content_name: el.dataset.label || el.dataset.track,
              button_name: el.dataset.track,
              page_name: "link_hub"
            });
          });
        });
      }

      function bindScrollTracking() {
        let tracked25 = false;
        let tracked60 = false;

        window.addEventListener(
          "scroll",
          () => {
            const scrollable = document.documentElement.scrollHeight - window.innerHeight;
            if (scrollable <= 0) return;

            const progress = (window.scrollY / scrollable) * 100;

            if (!tracked25 && progress >= 25) {
              tracked25 = true;
              trackEvent("ViewContent", {
                content_name: "scroll_25",
                page_name: "link_hub"
              });
            }

            if (!tracked60 && progress >= 60) {
              tracked60 = true;
              trackEvent("ViewContent", {
                content_name: "scroll_60",
                page_name: "link_hub"
              });
            }
          },
          { passive: true }
        );
      }

      function bindModalButtons() {
        const buttons = document.querySelectorAll("[data-modal]");
        buttons.forEach((button) => {
          button.addEventListener("click", () => openModal(button.dataset.modal));
        });
      }

      applyConfig();

      if (shareButton) shareButton.addEventListener("click", sharePage);
      if (closeModalButton) closeModalButton.addEventListener("click", closeModal);
      if (confirmModalButton) confirmModalButton.addEventListener("click", closeModal);

      if (modalOverlay) {
        modalOverlay.addEventListener("click", (event) => {
          if (event.target === modalOverlay) closeModal();
        });
      }

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modalOverlay && !modalOverlay.classList.contains("hidden")) {
          closeModal();
        }
      });

      window.addEventListener("load", () => {
        persistAttribution();
        appendAttributionToLinks();
        bindTrackedLinks();
        bindScrollTracking();
        bindModalButtons();

        trackEvent("ViewContent", {
          content_name: "landing_loaded",
          page_name: "link_hub"
        });
      });
    })();
  </script>
